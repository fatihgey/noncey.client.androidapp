<?xml version="1.0" encoding="utf-8"?>
<!--
  Top-bar logo icon — shown next to the title in the ActionBar.
  24×24dp, white strokes on transparent — reads on the dark (#1a1a2e) toolbar.
  Simplified: 2 asterisks + cursor (no card background at this size).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Two 6-arm asterisks -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.5"
        android:strokeLineCap="round"
        android:fillColor="@android:color/transparent"
        android:pathData="
            M7,8 L7,16
            M3.97,10 L10.03,14
            M3.97,14 L10.03,10
            M15,8 L15,16
            M11.97,10 L18.03,14
            M11.97,14 L18.03,10"/>

    <!-- Cursor bar -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M20,5 L22,5 L22,19 L20,19 Z"/>

</vector>
